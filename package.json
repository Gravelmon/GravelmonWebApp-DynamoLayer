{
  "name": "gravelmon-dynamodb",
  "version": "0.1.0",
  "description": "Node.js runtime contents for the DynamoDB Lambda layer.",
  "main": "./dist/package/layer-example.js",
  "types": "./dist/package/layer-example.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest --runInBand",
    "test:integration": "cross-env NODE_OPTIONS=--experimental-vm-modules jest lib/__tests__/it --testMatch='**/*.integration.test.ts' --runInBand",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch --runInBand"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "archiver": "^6.0.0",
    "cross-env": "^10.1.0",
    "jest": "^29.5.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.358.0",
    "@aws-sdk/lib-dynamodb": "^3.1040.0",
    "@aws-sdk/util-dynamodb": "^3.358.0",
    "aws-cdk-lib": "^2.252.0",
    "constructs": "^10.0.0"
  }
}
